{
    "manifest_version": 2,
    "name": "Browser Control MCP",
    "version": "1.0",
    "description": "A simple extension that allows a local MCP server to perform actions on the browser.",
    "permissions": [
        "tabs",
        "*://*/*",
        "history",
        "find"
    ],
    "browser_specific_settings": {
      "gecko": {
        "id": "browser-control-mcp@local"
      }
    },
    "background": {
      "scripts": ["dist/background.js"]
    }
  }
